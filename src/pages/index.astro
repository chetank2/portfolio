---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navigation from "../components/astro/Navigation.astro";
import Hero from "../components/astro/Hero.astro";
import SectionHeading from "../components/astro/SectionHeading.astro";
import ProjectCard from "../components/astro/ProjectCard.astro";
import AIProjectCard from "../components/astro/AIProjectCard.astro";
import ArticleCard from "../components/astro/ArticleCard.astro";
import TimelineItem from "../components/astro/TimelineItem.astro";
import MachinePageShell from "../components/astro/MachinePageShell.astro";
import ViewModeToggle from "../components/astro/ViewModeToggle.astro";
import Footer from "../components/astro/Footer.astro";
import ScrollReveal from "../components/react/ScrollReveal.tsx";
import {
  deepProjects,
  aiProjects,
  experience,
  article,
} from "../data/projects";

function formatProjectLine(project: (typeof deepProjects)[number] | (typeof aiProjects)[number]) {
  const href = project.caseStudyUrl ?? "#";
  if (project.protected) {
    return `- ${project.title} — ${project.tagline} (${href}, protected)`;
  }

  if (project.caseStudyUrl?.startsWith("/work/")) {
    return `- ${project.title} — ${project.tagline} (${project.caseStudyUrl}, /machine${project.caseStudyUrl})`;
  }

  return `- ${project.title} — ${project.tagline} (${href})`;
}

const homeMachineText = [
  "# Chetan Kummari",
  "> Senior Product Designer focused on complex B2B systems, design systems, and AI-assisted product building.",
  "",
  "## Work",
  ...deepProjects.map(formatProjectLine),
  "- More work: /work",
  "",
  "## Built with AI",
  ...aiProjects.map(formatProjectLine),
  "",
  "## Experience",
  ...experience.flatMap((exp) => [
    `### ${exp.role} — ${exp.company}`,
    `- Location: ${exp.location}`,
    `- Period: ${exp.period}`,
    ...exp.highlights.map((highlight) => `- ${highlight}`),
    "",
  ]),
  "## Writing",
  `- ${article.title} — ${article.summary} (${article.url})`,
  "",
  "## Contact",
  "- Resume: https://drive.google.com/file/d/1KQSSWbCDAwvKiQgXSI1ssj7m3p-vtZmD/view",
  "- Email: mailto:mymailchetan25@gmail.com",
  "- X: https://x.com/kchetank19",
  "- LinkedIn: https://linkedin.com/in/chetan-kumar25/",
  "- GitHub: https://github.com/chetank2",
].join("\n");
---

<BaseLayout>
  <div data-view-panel="human">
    <Navigation />
  </div>

  <main id="main">
    <div data-view-panel="machine" hidden class="bg-bg-deep min-h-screen">
      <MachinePageShell
        title="Chetan Kummari"
        pageHref="/"
        pageLabel="portfolio page"
        text={homeMachineText}
      />
    </div>

    <div data-view-panel="human">
    <!-- Hero -->
    <Hero />

    <!-- Selected Work -->
    <section class="section-padding" id="work">
      <div class="max-w-[1200px] 2xl:max-w-[1600px] mx-auto px-5 sm:px-6 md:px-12 2xl:px-24">
        <ScrollReveal client:load>
          <SectionHeading label="Work" title="Case Studies" />
        </ScrollReveal>

        <div class="grid sm:grid-cols-2 gap-5 sm:gap-6 2xl:gap-8">
          {deepProjects.map((project, i) => (
            <ScrollReveal client:load delay={i * 0.12}>
              <ProjectCard
                title={project.title}
                tagline={project.tagline}
                description={project.description}
                tags={project.tags}
                protected={project.protected}
                href={project.caseStudyUrl}
              />
            </ScrollReveal>
          ))}
        </div>

        <ScrollReveal client:load delay={0.12}>
          <div class="mt-10 flex justify-start">
            <a
              href="/work"
              class="inline-flex items-center gap-2 radius-xl border border-border bg-bg-elevated/60 px-4 py-2.5 type-button text-text-secondary transition-colors duration-300 hover:text-text-primary hover:border-border-hover"
            >
              View more
              <span aria-hidden="true">&rarr;</span>
            </a>
          </div>
        </ScrollReveal>
      </div>
    </section>

    <!-- Divider -->
    <div class="max-w-[1200px] 2xl:max-w-[1600px] mx-auto px-5 sm:px-6 md:px-12 2xl:px-24">
      <hr class="section-divider" />
    </div>

    <!-- Built with AI -->
    <section class="section-padding bg-bg-surface" id="ai">
      <div class="max-w-[1200px] 2xl:max-w-[1600px] mx-auto px-5 sm:px-6 md:px-12 2xl:px-24">
        <ScrollReveal client:load>
          <SectionHeading label="Builder" title="Built with AI" />
        </ScrollReveal>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6 2xl:gap-8">
          {aiProjects.map((project, i) => (
            <ScrollReveal client:load delay={i * 0.12}>
              <AIProjectCard
                title={project.title}
                tagline={project.tagline}
                description={project.description}
                tags={project.tags}
                liveUrl={project.liveUrl}
                repoUrl={project.repoUrl}
                caseStudyUrl={project.caseStudyUrl}
              />
            </ScrollReveal>
          ))}
        </div>
      </div>
    </section>

    <!-- Divider -->
    <div class="max-w-[1200px] 2xl:max-w-[1600px] mx-auto px-5 sm:px-6 md:px-12 2xl:px-24">
      <hr class="section-divider" />
    </div>

    <!-- Writing -->
    <section class="section-padding" id="writing">
      <div class="max-w-[1200px] 2xl:max-w-[1600px] mx-auto px-5 sm:px-6 md:px-12 2xl:px-24">
        <ScrollReveal client:load>
          <SectionHeading label="Writing" title="Articles" />
        </ScrollReveal>
        <ScrollReveal client:load>
          <div class="max-w-2xl">
            <ArticleCard
              title={article.title}
              date={article.date}
              categories={article.categories}
              summary={article.summary}
              url={article.url}
            />
          </div>
        </ScrollReveal>
      </div>
    </section>

    <!-- Resume -->
    <section class="section-padding bg-bg-surface" id="resume">
      <div class="max-w-[1200px] 2xl:max-w-[1600px] mx-auto px-5 sm:px-6 md:px-12 2xl:px-24">
        <ScrollReveal client:load>
          <SectionHeading label="Experience" title="Experience" />
          <p class="type-section-intro text-text-secondary -mt-8 mb-14 max-w-2xl">
            I've worked across logistics, warehouse operations, and product platforms, mostly on systems where the challenge is less about visual polish and more about clarity under complexity.
          </p>
        </ScrollReveal>

        <div class="space-y-0">
          {experience.map((exp, i) => (
            <ScrollReveal client:load delay={i * 0.1}>
              <TimelineItem
                role={exp.role}
                company={exp.company}
                location={exp.location}
                period={exp.period}
                highlights={exp.highlights}
                isFirst={i === 0}
                isLast={i === experience.length - 1}
              />
            </ScrollReveal>
          ))}
        </div>
      </div>
    </section>

    <!-- Contact -->
    <section class="section-padding contact-section" id="contact">
      <div class="max-w-[1200px] 2xl:max-w-[1600px] mx-auto px-5 sm:px-6 md:px-12 2xl:px-24">
        <ScrollReveal client:load>
          <div class="contact-panel">
            <SectionHeading label="Contact" title="Let's Build Better Systems" />
            <a
              href="mailto:mymailchetan25@gmail.com"
              class="contact-email -mt-8 inline-flex items-center justify-start text-text-secondary transition-colors duration-300 hover:text-text-primary"
            >
              mymailchetan25@gmail.com
            </a>
          </div>
        </ScrollReveal>
      </div>
    </section>
    </div>
  </main>

  <ViewModeToggle />
  <div data-view-panel="human">
    <Footer />
  </div>
</BaseLayout>
