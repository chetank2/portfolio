---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navigation from "../../components/astro/Navigation.astro";
import Footer from "../../components/astro/Footer.astro";
import MachinePageShell from "../../components/astro/MachinePageShell.astro";
import ViewModeToggle from "../../components/astro/ViewModeToggle.astro";
import CaseStudyRelatedLinks from "../../components/astro/CaseStudyRelatedLinks.astro";
import ScrollReveal from "../../components/react/ScrollReveal.tsx";
import ProtectedCaseStudy from "../../components/react/ProtectedCaseStudy.tsx";
import { caseStudies } from "../../data/caseStudies";
import { getProjectLinksBySlug, portfolioMachineLinks } from "../../data/projects";
import {
  SHARED_CASE_STUDY_PASSWORD,
  isProtectedCaseStudy,
} from "../../lib/caseStudyProtection";
import { loadMachineCaseStudyContent } from "../../lib/machine/content.js";
import { serializeMachineCaseStudy } from "../../lib/machine/serialize.js";

const contentModules = import.meta.glob("../../../content/case-study-*.md");

export function getStaticPaths() {
  return caseStudies.map((caseStudy) => ({
    params: { slug: caseStudy.slug },
    props: { caseStudy },
  }));
}

const { caseStudy } = Astro.props;
const modulePath = `../../../content/${caseStudy.contentFile}`;
const contentLoader = contentModules[modulePath];
const requiresProtection =
  caseStudy.protected ?? isProtectedCaseStudy(caseStudy.slug);
const machineText = await loadMachineCaseStudyContent(caseStudy).then((content) =>
  serializeMachineCaseStudy({ ...caseStudy, origin: "markdown" }, content),
);
const relatedLinks = getProjectLinksBySlug(caseStudy.slug);
const machineRelatedLinksText = relatedLinks.length
  ? [
      "",
      "## Related Links",
      ...relatedLinks.map((link) => `- ${link.title}: ${link.href}`),
    ].join("\n")
  : "";

// Compute prev/next case studies
const currentIndex = caseStudies.findIndex((cs) => cs.slug === caseStudy.slug);
const prevStudy = currentIndex > 0 ? caseStudies[currentIndex - 1] : null;
const nextStudy = currentIndex < caseStudies.length - 1 ? caseStudies[currentIndex + 1] : null;
const siteHref = portfolioMachineLinks.siteHref.replace(/\/$/, "");
const machineNavigationText =
  prevStudy || nextStudy
    ? [
        "",
        "## Navigation",
        prevStudy ? `- Previous: ${prevStudy.title} (${siteHref}/work/${prevStudy.slug})` : "",
        nextStudy ? `- Next: ${nextStudy.title} (${siteHref}/work/${nextStudy.slug})` : "",
      ]
        .filter(Boolean)
        .join("\n")
    : "";
const machinePageText = `${machineText}${machineRelatedLinksText}${machineNavigationText}`;

let Content;
if (!contentLoader) {
  throw new Error(`Missing case study content for ${caseStudy.slug}`);
}

const contentModule = await contentLoader();
Content = contentModule.default;
---

<BaseLayout title={`${caseStudy.title} — Chetan Kummari`}>
  <div data-view-panel="human">
    <Navigation />
  </div>
  <main id="main">
    <div data-view-panel="human" class="bg-bg-deep min-h-screen pt-20 sm:pt-24 md:pt-28 pb-16 sm:pb-20 px-5 sm:px-6">
      <div class="max-w-3xl 2xl:max-w-4xl mx-auto">
        {requiresProtection ? (
          <div
            class="mt-2 sm:mt-4 mb-8 sm:mb-10 flex items-center justify-between gap-4"
            data-case-study-topbar
            data-storage-key={`case-study:${caseStudy.slug}`}
          >
            <a
              href={caseStudy.backHref}
              class="type-ui-meta inline-flex items-center gap-2 text-text-tertiary hover:text-accent transition-colors duration-300"
            >
              <span class="w-4 h-px bg-text-tertiary"></span>
              Back
            </a>
            <button
              type="button"
              hidden
              data-case-study-lock
              class="inline-flex items-center gap-2 radius-xl border border-border bg-bg-elevated/60 px-4 py-2 font-display text-[10px] uppercase tracking-[0.18em] text-text-secondary transition-colors hover:text-text-primary"
            >
              <svg
                aria-hidden="true"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="h-4 w-4"
              >
                <rect x="4" y="11" width="16" height="9" rx="2" />
                <path d="M8 11V8a4 4 0 1 1 8 0v3" />
              </svg>
              Lock again
            </button>
          </div>
        ) : (
          <a
            href={caseStudy.backHref}
            class="type-ui-meta inline-flex items-center gap-2 text-text-tertiary hover:text-accent transition-colors duration-300"
          >
            <span class="w-4 h-px bg-text-tertiary"></span>
            Back
          </a>
        )}
        {requiresProtection ? (
          <ProtectedCaseStudy
            client:load
            password={SHARED_CASE_STUDY_PASSWORD}
            storageKey={`case-study:${caseStudy.slug}`}
            title={caseStudy.title}
          >
            <ScrollReveal client:visible>
              <header class="mt-8 sm:mt-12 mb-12 sm:mb-16 md:mb-20">
                <h1 class="type-page-title text-text-primary mb-4 sm:mb-5">
                  {caseStudy.title}
                </h1>
                <p class="type-page-tagline text-text-secondary italic mb-10">
                  {caseStudy.tagline}
                </p>
                <div class="type-ui-meta flex flex-wrap gap-x-8 gap-y-3 text-text-secondary">
                  <span><span class="text-accent/60">Role</span> <span class="mx-1 text-text-tertiary">/</span> {caseStudy.role}</span>
                  <span><span class="text-accent/60">Company</span> <span class="mx-1 text-text-tertiary">/</span> {caseStudy.company}</span>
                  <span><span class="text-accent/60">Timeline</span> <span class="mx-1 text-text-tertiary">/</span> {caseStudy.timeline}</span>
                </div>
              </header>
            </ScrollReveal>

            <ScrollReveal client:visible>
              <article class="longform-content case-study-content mb-20">
                <Content />
              </article>
            </ScrollReveal>

            <CaseStudyRelatedLinks links={relatedLinks} />

            {(prevStudy || nextStudy) && (
              <nav class="flex items-stretch justify-between gap-4 border-t border-border pt-10 mb-20">
                {prevStudy ? (
                  <a href={`/work/${prevStudy.slug}`} class="group flex flex-col items-start gap-1.5 max-w-[45%]">
                    <span class="font-display text-[10px] uppercase tracking-widest text-text-tertiary group-hover:text-accent transition-colors duration-300">&larr; Previous</span>
                    <span class="type-body-sm text-text-secondary group-hover:text-text-primary transition-colors duration-300">{prevStudy.title}</span>
                  </a>
                ) : <div />}
                {nextStudy ? (
                  <a href={`/work/${nextStudy.slug}`} class="group flex flex-col items-end gap-1.5 max-w-[45%] text-right ml-auto">
                    <span class="font-display text-[10px] uppercase tracking-widest text-text-tertiary group-hover:text-accent transition-colors duration-300">Next &rarr;</span>
                    <span class="type-body-sm text-text-secondary group-hover:text-text-primary transition-colors duration-300">{nextStudy.title}</span>
                  </a>
                ) : <div />}
              </nav>
            )}
          </ProtectedCaseStudy>
        ) : (
          <>
            <ScrollReveal client:visible>
              <header class="mt-8 sm:mt-12 mb-12 sm:mb-16 md:mb-20">
                <h1 class="type-page-title text-text-primary mb-4 sm:mb-5">
                  {caseStudy.title}
                </h1>
                <p class="type-page-tagline text-text-secondary italic mb-10">
                  {caseStudy.tagline}
                </p>
                <div class="type-ui-meta flex flex-wrap gap-x-8 gap-y-3 text-text-secondary">
                  <span><span class="text-accent/60">Role</span> <span class="mx-1 text-text-tertiary">/</span> {caseStudy.role}</span>
                  <span><span class="text-accent/60">Company</span> <span class="mx-1 text-text-tertiary">/</span> {caseStudy.company}</span>
                  <span><span class="text-accent/60">Timeline</span> <span class="mx-1 text-text-tertiary">/</span> {caseStudy.timeline}</span>
                </div>
              </header>
            </ScrollReveal>

            <ScrollReveal client:visible>
              <article class="longform-content case-study-content mb-20">
                <Content />
              </article>
            </ScrollReveal>

            <CaseStudyRelatedLinks links={relatedLinks} />

            {(prevStudy || nextStudy) && (
              <nav class="flex items-stretch justify-between gap-4 border-t border-border pt-10 mb-20">
                {prevStudy ? (
                  <a href={`/work/${prevStudy.slug}`} class="group flex flex-col items-start gap-1.5 max-w-[45%]">
                    <span class="font-display text-[10px] uppercase tracking-widest text-text-tertiary group-hover:text-accent transition-colors duration-300">&larr; Previous</span>
                    <span class="type-body-sm text-text-secondary group-hover:text-text-primary transition-colors duration-300">{prevStudy.title}</span>
                  </a>
                ) : <div />}
                {nextStudy ? (
                  <a href={`/work/${nextStudy.slug}`} class="group flex flex-col items-end gap-1.5 max-w-[45%] text-right ml-auto">
                    <span class="font-display text-[10px] uppercase tracking-widest text-text-tertiary group-hover:text-accent transition-colors duration-300">Next &rarr;</span>
                    <span class="type-body-sm text-text-secondary group-hover:text-text-primary transition-colors duration-300">{nextStudy.title}</span>
                  </a>
                ) : <div />}
              </nav>
            )}
          </>
        )}
      </div>
    </div>
    <div data-view-panel="machine" hidden class="bg-bg-deep min-h-screen">
      {requiresProtection ? (
        <ProtectedCaseStudy
          client:load
          password={SHARED_CASE_STUDY_PASSWORD}
          storageKey={`case-study:${caseStudy.slug}`}
          title={caseStudy.title}
        >
          <MachinePageShell
            title={caseStudy.title}
            pageHref={`/work/${caseStudy.slug}`}
            text={machinePageText}
          />
        </ProtectedCaseStudy>
      ) : (
        <MachinePageShell
          title={caseStudy.title}
          pageHref={`/work/${caseStudy.slug}`}
          text={machinePageText}
        />
      )}
    </div>
  </main>
  <ViewModeToggle />
  <div data-view-panel="human">
    <Footer />
  </div>
</BaseLayout>

<script is:inline>
  (() => {
    const syncTopBars = () => {
      document.querySelectorAll("[data-case-study-topbar]").forEach((toolbar) => {
        if (!(toolbar instanceof HTMLElement)) return;
        const storageKey = toolbar.dataset.storageKey;
        const button = toolbar.querySelector("[data-case-study-lock]");
        if (!storageKey || !(button instanceof HTMLButtonElement)) return;

        button.hidden = window.sessionStorage.getItem(storageKey) !== "unlocked";
      });
    };

    document.addEventListener("click", (event) => {
      const button = event.target instanceof Element
        ? event.target.closest("[data-case-study-lock]")
        : null;
      if (!(button instanceof HTMLButtonElement)) return;

      const toolbar = button.closest("[data-case-study-topbar]");
      if (!(toolbar instanceof HTMLElement)) return;

      const storageKey = toolbar.dataset.storageKey;
      if (!storageKey) return;

      window.sessionStorage.removeItem(storageKey);
      window.dispatchEvent(
        new CustomEvent("case-study-protection-change", {
          detail: { key: storageKey, state: "locked" },
        }),
      );
      syncTopBars();
    });

    window.addEventListener("storage", syncTopBars);
    window.addEventListener("case-study-protection-change", syncTopBars);
    syncTopBars();
  })();
</script>
