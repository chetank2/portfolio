---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navigation from "../../components/astro/Navigation.astro";
import Footer from "../../components/astro/Footer.astro";
import ProtectedCaseStudy from "../../components/react/ProtectedCaseStudy.tsx";
import CaseStudyView from "../../components/astro/CaseStudyView.astro";
import MachineTextBlock from "../../components/astro/MachineTextBlock.astro";
import ViewModeToggle from "../../components/astro/ViewModeToggle.astro";
import {
  standaloneCaseStudies,
  standaloneCaseStudyMachineText,
} from "../../data/standaloneCaseStudies";
import { SHARED_CASE_STUDY_PASSWORD } from "../../lib/caseStudyProtection";

const study = standaloneCaseStudies["journey-redesign"];
---

<BaseLayout title={`${study.title} — Chetan Kummari`}>
  <div data-view-panel="human">
    <Navigation />
  </div>
  <main id="main">
    <div data-view-panel="human" class="bg-bg-deep min-h-screen pt-20 sm:pt-24 md:pt-28 pb-16 sm:pb-20 px-5 sm:px-6">
      <div class="max-w-3xl 2xl:max-w-4xl mx-auto">
        <a href={study.backHref} class="inline-flex items-center gap-2 font-mono text-xs text-text-tertiary hover:text-accent transition-colors duration-300">
          <span class="w-4 h-px bg-text-tertiary"></span>
          Back
        </a>
        <ProtectedCaseStudy
          client:load
          password={SHARED_CASE_STUDY_PASSWORD}
          storageKey={`case-study:${study.slug}`}
          title={study.title}
        >
          <CaseStudyView study={study} />
        </ProtectedCaseStudy>
      </div>
    </div>
    <div data-view-panel="machine" hidden class="bg-bg-deep min-h-screen">
      <ProtectedCaseStudy
        client:load
        password={SHARED_CASE_STUDY_PASSWORD}
        storageKey={`case-study:${study.slug}`}
        title={study.title}
      >
        <MachineTextBlock text={standaloneCaseStudyMachineText[study.slug]} />
      </ProtectedCaseStudy>
    </div>
  </main>
  <ViewModeToggle />
  <div data-view-panel="human">
    <Footer />
  </div>
</BaseLayout>
