---
import ProjectCardHover from "../react/ProjectCardHover.tsx";

interface Props {
  title: string;
  tagline: string;
  description: string;
  tags: string[];
  protected?: boolean;
  liveUrl?: string;
  npmUrl?: string;
  caseStudyUrl?: string;
}

const {
  title,
  tagline,
  description,
  tags,
  protected: isProtected = false,
  liveUrl,
  npmUrl,
  caseStudyUrl,
} = Astro.props;
---

<ProjectCardHover client:visible>
  <a href={caseStudyUrl ?? liveUrl ?? npmUrl ?? "#"} class="block h-full no-underline">
    <div class="p-6 h-full flex flex-col">
      <div class="flex items-start justify-between gap-4">
        <h3 class="text-lg font-display font-700 text-text-primary">{title}</h3>
        {isProtected && (
          <span class="inline-flex shrink-0 items-center gap-1.5 radius-xl border border-border bg-bg-elevated/70 px-2.5 py-1 font-mono text-[10px] uppercase tracking-[0.18em] text-accent/80">
            <svg
              aria-hidden="true"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-3.5 w-3.5"
            >
              <rect x="4" y="11" width="16" height="9" rx="2" />
              <path d="M8 11V8a4 4 0 1 1 8 0v3" />
            </svg>
            Locked
          </span>
        )}
      </div>
      <p class="text-text-secondary font-body text-sm italic mt-1.5">{tagline}</p>
      <p class="text-text-secondary font-body text-sm mt-3 flex-1 leading-relaxed">{description}</p>

      <div class="flex flex-wrap gap-2 mt-5">
        {tags.map((tag) => (
          <span class="tag-pill">{tag}</span>
        ))}
      </div>
    </div>
  </a>
</ProjectCardHover>
