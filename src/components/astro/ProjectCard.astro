---
interface Props {
  title: string;
  tagline: string;
  description: string;
  tags: string[];
  protected?: boolean;
  href?: string;
  cardImageLight?: string;
  cardImageDark?: string;
}

const {
  title,
  tagline,
  protected: isProtected = false,
  href,
  cardImageLight,
  cardImageDark,
} = Astro.props as Props;
---

<a href={href ?? "#"} class="featured-case-card group block no-underline">
  <div class="featured-case-card__surface border border-border radius-xl">
    <div class="featured-case-card__media">
      {cardImageLight ? (
        <img
          src={cardImageLight}
          alt={title}
          class="featured-case-card__image hero-image--light"
          loading="lazy"
        />
      ) : null}
      {cardImageDark || cardImageLight ? (
        <img
          src={cardImageDark ?? cardImageLight}
          alt={title}
          class="featured-case-card__image hero-image--dark"
          loading="lazy"
        />
      ) : null}
      <div class="featured-case-card__shade"></div>
      {isProtected ? (
        <span class="featured-case-card__lock featured-case-card__lock--floating" aria-label="Protected case study">
          <svg
            aria-hidden="true"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-5 w-5"
          >
            <rect x="4" y="11" width="16" height="9" rx="2" />
            <path d="M8 11V8a4 4 0 1 1 8 0v3" />
          </svg>
        </span>
      ) : null}
    </div>

    <div class="featured-case-card__panel">
      <div class="featured-case-card__panel-top">
        <h3 class="featured-case-card__title">{title}</h3>
        <span class="featured-case-card__spacer" aria-hidden="true"></span>
      </div>
      <p class="featured-case-card__tagline">{tagline}</p>
    </div>
  </div>
</a>
