---
import ProjectCardHover from "../react/ProjectCardHover.tsx";

interface Props {
  title: string;
  tagline: string;
  description: string;
  tags: string[];
  href?: string;
}

const { title, tagline, description, tags, href } = Astro.props;
---

<ProjectCardHover client:visible>
  <div class="p-8 md:p-10 h-full flex flex-col">
    <h3 class="text-xl md:text-2xl font-display font-700 text-text-primary">{title}</h3>
    <p class="text-text-secondary font-body italic mt-2">{tagline}</p>
    <p class="text-text-secondary font-body text-[0.9375rem] mt-5 flex-1 leading-relaxed">{description}</p>

    <div class="flex flex-wrap gap-2 mt-7">
      {tags.map((tag) => (
        <span class="tag-pill">{tag}</span>
      ))}
    </div>

    {href && (
      <div class="mt-7 pt-6 border-t border-border">
        <a
          href={href}
          class="font-mono text-xs text-text-secondary hover:text-accent link-hover transition-colors duration-300"
        >
          Read Case Study &rarr;
        </a>
      </div>
    )}
  </div>
</ProjectCardHover>
