---
interface Props {
  title: string;
  tagline: string;
  image: string;
}

const { title, tagline, image } = Astro.props;
---

<div class="border border-border bg-bg-surface overflow-hidden group card-accent transition-all duration-400 hover:border-border-hover">
  <div class="aspect-video overflow-hidden">
    <img
      src={image}
      alt={title}
      class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
      loading="lazy"
    />
  </div>
  <div class="p-5">
    <h3 class="font-display font-700 text-text-primary">{title}</h3>
    <p class="text-text-secondary font-body text-sm mt-1">{tagline}</p>
  </div>
</div>
