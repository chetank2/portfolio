---
import type { ProjectLink } from "../../data/projects";

interface Props {
  links: ProjectLink[];
}

const { links } = Astro.props as Props;
---

{links.length ? (
  <section class="mt-20 mb-20">
    <h3 class="case-study-section-title mb-6 text-text-primary">Related Links</h3>
    <div class="space-y-4">
      {links.map((link) => (
        <a
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          class="block radius-lg border border-border bg-bg-elevated/60 p-6 hover:border-accent-border transition-colors duration-300"
        >
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="type-card-title-md text-text-primary">{link.title}</p>
              <p class="type-body-sm text-text-secondary mt-1">{link.description}</p>
            </div>
            <span class="text-accent">&nearr;</span>
          </div>
        </a>
      ))}
    </div>
  </section>
) : null}
