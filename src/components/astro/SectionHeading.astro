---
interface Props {
  label?: string;
  title: string;
  number?: string;
  id?: string;
  centered?: boolean;
}

const { label, title, number, id, centered = false } = Astro.props;
---

<div class:list={["mb-14", centered && "text-center"]} id={id}>
  <div class:list={["flex items-center gap-3 mb-4", centered && "justify-center"]}>
    {number && (
      <span class="section-number">{number} /</span>
    )}
    {label && (
      <span class="type-ui-label text-text-tertiary">{label}</span>
    )}
  </div>
  <h2 class="type-section-heading text-text-primary">
    {title}
  </h2>
</div>
