---
interface Props {
  label?: string;
  title: string;
  number?: string;
  id?: string;
}

const { label, title, number, id } = Astro.props;
---

<div class="mb-14" id={id}>
  <div class="flex items-center gap-3 mb-4">
    {number && (
      <span class="section-number">{number} /</span>
    )}
    {label && (
      <span class="font-mono text-xs tracking-wide text-text-tertiary uppercase">{label}</span>
    )}
  </div>
  <h2 class="text-2xl sm:text-3xl md:text-[2.75rem] 2xl:text-5xl font-display font-700 text-text-primary leading-tight">
    {title}
  </h2>
</div>
