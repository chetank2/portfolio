---
interface Props {
  label?: string;
  title: string;
  id?: string;
}

const { label, title, id } = Astro.props;
---

<div class="mb-12" id={id}>
  {label && (
    <span class="text-xs font-medium uppercase tracking-[0.1em] text-text-tertiary mb-3 block">
      {label}
    </span>
  )}
  <h2 class="text-3xl md:text-4xl font-semibold text-text-primary">
    {title}
  </h2>
</div>
