---
import NavigationMenu from "../react/NavigationMenu.tsx";

const links = [
  { label: "Work", href: "#work", number: "01" },
  { label: "Built with AI", href: "#ai", number: "02" },
  { label: "Writing", href: "#writing", number: "03" },
  { label: "Resume", href: "#resume", number: "04" },
  { label: "Contact", href: "#contact", number: "05" },
];
---

<header
  class="fixed top-0 left-0 right-0 z-50 border-b border-border/60"
  style="background: rgba(11, 10, 8, 0.85); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);"
>
  <nav class="max-w-[1200px] 2xl:max-w-[1600px] mx-auto px-5 sm:px-6 md:px-12 2xl:px-24 h-14 sm:h-16 2xl:h-20 flex items-center justify-between">
    <a href="/" class="font-display text-lg font-700 text-text-primary hover:text-accent transition-colors duration-300">
      చే.
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-8">
      {links.map((link) => (
        <a
          href={link.href}
          class="flex items-baseline gap-1.5 text-text-secondary hover:text-accent transition-colors duration-300 link-hover"
        >
          <span class="font-mono text-[10px] text-accent/60">{link.number}</span>
          <span class="font-mono text-xs">{link.label}</span>
        </a>
      ))}
    </div>

    <!-- Mobile nav -->
    <div class="md:hidden">
      <NavigationMenu client:load links={links} />
    </div>
  </nav>
</header>
