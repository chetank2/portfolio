---
import ProjectCardHover from "../react/ProjectCardHover.tsx";

interface Props {
  title: string;
  tagline: string;
  description: string;
  tags: string[];
  liveUrl?: string;
  repoUrl?: string;
  caseStudyUrl?: string;
}

const { title, tagline, description, tags, liveUrl, repoUrl, caseStudyUrl } = Astro.props;
---

<ProjectCardHover client:visible>
  <a href={caseStudyUrl ?? liveUrl ?? repoUrl ?? "#"} class="block h-full no-underline">
    <div class="p-6 h-full flex flex-col">
      <span class="ai-badge inline-flex items-center gap-1.5 font-mono text-[10px] uppercase tracking-wider mb-4 px-2.5 py-1 w-fit border">
        Built with AI
      </span>

      <h3 class="text-lg font-display font-700 text-text-primary">{title}</h3>
      <p class="text-text-secondary font-body text-sm italic mt-1.5">{tagline}</p>
      <p class="text-text-secondary font-body text-sm mt-3 flex-1 leading-relaxed">{description}</p>

      <div class="flex flex-wrap gap-2 mt-5">
        {tags.map((tag) => (
          <span class="tag-pill">{tag}</span>
        ))}
      </div>
    </div>
  </a>
</ProjectCardHover>
