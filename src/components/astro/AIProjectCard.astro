---
import ProjectCardHover from "../react/ProjectCardHover.tsx";

interface Props {
  title: string;
  tagline: string;
  description: string;
  tags: string[];
  liveUrl?: string;
  repoUrl?: string;
}

const { title, tagline, description, tags, liveUrl, repoUrl } = Astro.props;
---

<ProjectCardHover client:visible>
  <div class="p-6 h-full flex flex-col">
    <span class="inline-flex items-center gap-1.5 text-xs uppercase tracking-wide mb-3 px-2.5 py-1 rounded-full w-fit"
      style="background: rgba(140,160,255,0.08); color: rgba(160,180,255,0.8); border: 1px solid rgba(140,160,255,0.1);">
      Built with AI
    </span>

    <h3 class="text-lg font-semibold text-text-primary">{title}</h3>
    <p class="text-text-secondary text-sm italic mt-1">{tagline}</p>
    <p class="text-text-secondary text-sm mt-3 flex-1">{description}</p>

    <div class="flex flex-wrap gap-2 mt-4">
      {tags.map((tag) => (
        <span class="text-xs bg-accent-muted text-text-secondary rounded-full px-3 py-1">
          {tag}
        </span>
      ))}
    </div>

    {(liveUrl || repoUrl) && (
      <div class="flex items-center gap-4 mt-4">
        {liveUrl && (
          <a
            href={liveUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-text-secondary hover:text-text-primary link-hover transition-colors"
          >
            View Live &#8599;
          </a>
        )}
        {repoUrl && (
          <a
            href={repoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-text-secondary hover:text-text-primary link-hover transition-colors"
          >
            GitHub &#8599;
          </a>
        )}
      </div>
    )}
  </div>
</ProjectCardHover>
