---
interface Props {
  role: string;
  company: string;
  location: string;
  period: string;
  highlights: string[];
  isFirst?: boolean;
}

const { role, company, location, period, highlights, isFirst = false } = Astro.props;
---

<div class="flex flex-col md:flex-row gap-4 md:gap-12">
  <!-- Period -->
  <div class="md:w-44 flex-shrink-0">
    <span class="type-ui-meta text-text-tertiary">{period}</span>
  </div>

  <!-- Timeline dot + content -->
  <div class="flex gap-5">
    <div class="flex flex-col items-center pt-2">
      <div
        class:list={[
          "w-2 h-2 rounded-full flex-shrink-0 transition-all",
          isFirst
            ? "bg-accent shadow-[0_0_12px_rgba(200,165,85,0.4)]"
            : "border border-border-hover bg-transparent",
        ]}
      ></div>
      <div class="w-px flex-1 bg-border mt-3"></div>
    </div>

    <div class="pb-12">
      <h3 class="type-card-title-md text-text-primary">{role}</h3>
      <p class="type-body-sm text-text-secondary mt-0.5">
        {company} <span class="text-text-tertiary mx-1">/</span> {location}
      </p>

      {highlights.length > 0 && (
        <ul class="mt-4 space-y-2.5">
          {highlights.map((highlight) => (
            <li class="type-body-sm text-text-secondary flex gap-3">
              <span class="text-accent/50 mt-0.5 flex-shrink-0">—</span>
              <span>{highlight}</span>
            </li>
          ))}
        </ul>
      )}
    </div>
  </div>
</div>
