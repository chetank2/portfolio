---
interface Props {
  role: string;
  company: string;
  location: string;
  period: string;
  highlights: string[];
  isFirst?: boolean;
}

const { role, company, location, period, highlights, isFirst = false } = Astro.props;
---

<div class="flex flex-col md:flex-row gap-4 md:gap-8">
  <!-- Period (left column on desktop) -->
  <div class="md:w-40 flex-shrink-0">
    <span class="text-sm text-text-tertiary">{period}</span>
  </div>

  <!-- Dot connector + content -->
  <div class="flex gap-4">
    <div class="flex flex-col items-center pt-2">
      <div
        class:list={[
          "w-2.5 h-2.5 rounded-full flex-shrink-0 transition-all",
          isFirst
            ? "bg-white shadow-[0_0_8px_rgba(255,255,255,0.4)]"
            : "bg-border-subtle",
        ]}
      ></div>
      <div class="w-px flex-1 bg-border-subtle mt-2"></div>
    </div>

    <div class="pb-10">
      <h3 class="font-semibold text-text-primary">{role}</h3>
      <p class="text-text-secondary text-sm">
        {company} &middot; {location}
      </p>

      {highlights.length > 0 && (
        <ul class="mt-3 space-y-2">
          {highlights.map((highlight) => (
            <li class="text-text-secondary text-sm flex gap-2">
              <span class="text-text-tertiary mt-1 flex-shrink-0">&bull;</span>
              <span>{highlight}</span>
            </li>
          ))}
        </ul>
      )}
    </div>
  </div>
</div>
